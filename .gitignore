# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# renv (project-local R packages — large, rebuildable from lockfile)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# Data files (raw and processed — should not be in git, will be pulled from Snowflake)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Output artifacts (regeneratable from code)
output/figures/*
output/tables/*
!output/figures/.gitkeep
!output/tables/.gitkeep

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls

# Environment / secrets
.env
.env.local
*.pem
*.key

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python (in case any utility scripts end up here)
__pycache__/
*.pyc
.venv/
venv/
